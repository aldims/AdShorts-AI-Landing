{
  "name": "adshortsai-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n auth,web \"npm:dev:server\" \"ADSHORTS_AUTO_AUTH_BACKEND=0 npm run dev:web\"",
    "dev:server": "tsx watch --include .env --include .env.* server/server.ts",
    "dev:server:detached": "node scripts/start-auth-dev-server.mjs",
    "dev:web": "node --max-http-header-size=65536 ./node_modules/vite/bin/vite.js --host 127.0.0.1",
    "build": "tsc && tsc -p tsconfig.server.json && vite build && node ../scripts/generate-app-route-shells.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit:responsive": "node scripts/responsive-audit.mjs",
    "audit:responsive:app": "RESPONSIVE_AUDIT_SCOPE=app node scripts/responsive-audit.mjs",
    "audit:responsive:app:quick": "RESPONSIVE_AUDIT_SCOPE=app RESPONSIVE_AUDIT_QUICK=1 node scripts/responsive-audit.mjs",
    "audit:responsive:static": "RESPONSIVE_AUDIT_SCOPE=static node scripts/responsive-audit.mjs",
    "preview": "concurrently -k -n auth,web \"npm:start:server\" \"ADSHORTS_AUTO_AUTH_BACKEND=0 npm run preview:web\"",
    "preview:web": "node --max-http-header-size=65536 ./node_modules/vite/bin/vite.js preview --host 127.0.0.1",
    "start:server": "node dist-server/server/server.js",
    "auth:generate": "npx auth@latest generate --config ./server/auth.ts --yes",
    "auth:migrate": "npx auth@latest migrate --config ./server/auth.ts --yes",
    "auth:sync-legacy": "tsx server/migrate-auth-data.ts",
    "auth:prepare-shared": "npm run auth:migrate && npm run auth:sync-legacy",
    "workspace:migrate-owner-keys": "tsx server/migrate-workspace-owner-keys.ts"
  },
  "dependencies": {
    "better-auth": "^1.5.6",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jose": "^6.2.3",
    "nodemailer": "^9.0.1",
    "pg": "^8.20.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.9.2",
    "sharp": "^0.34.4"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/nodemailer": "^7.0.11",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "jsdom": "^27.0.0",
    "playwright": "^1.59.1",
    "supertest": "^7.1.4",
    "typescript": "~5.9.3",
    "tsx": "^4.22.4",
    "vite": "^8.0.1",
    "vitest": "^4.1.9"
  }
}
