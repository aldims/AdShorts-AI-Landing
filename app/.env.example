APP_URL=http://127.0.0.1:4174
BETTER_AUTH_URL=http://127.0.0.1:4174
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
AUTH_SERVER_PORT=4175
AUTH_DATABASE_PATH=./data/auth.sqlite

# SMTP for real email delivery. If omitted, local dev falls back to Ethereal preview inbox.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
# Для Gmail: пароль приложения; если в нём пробелы — весь строковый литерал в кавычках, иначе dotenv обрежет значение.
# SMTP_PASS="abcd efgh ijkl mnop"
SMTP_PASS=
# Для Gmail лучше тот же адрес, что и SMTP_USER, пока не настроите «Отправлять от имени» в Gmail.
SMTP_FROM=AdShorts AI <no-reply@adshorts.ai>

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Telegram OIDC login
# 1. Создайте бота через @BotFather: /newbot
# 2. Включите Web Login: Bot Settings → Web Login
#    Redirect URI для dev: http://127.0.0.1:4174/api/auth/telegram/oidc/callback
#    Trusted Origin для dev: http://127.0.0.1:4174
# 3. TELEGRAM_BOT_ID — Client ID из Web Login, обычно числовой id бота
# 4. TELEGRAM_CLIENT_SECRET — Client Secret из Web Login, нужен для надежного server-side OIDC flow
# 5. TELEGRAM_BOT_USERNAME — имя бота без @, например: AdshortsAIBot
# 6. TELEGRAM_BOT_TOKEN нужен только для старого HMAC callback
TELEGRAM_BOT_ID=
TELEGRAM_CLIENT_SECRET=
TELEGRAM_BOT_USERNAME=
TELEGRAM_BOT_TOKEN=

# Payment checkout links. If empty, the app falls back to AdsFlow dynamic checkout.
# AdsFlow API base URL. For local frontend against server API use: https://api.adshortsai.com
ADSFLOW_API_BASE_URL=
PAYMENT_BASE_URL=
PAYMENT_LINK_START=
PAYMENT_LINK_PRO=
PAYMENT_LINK_ULTRA=
PAYMENT_LINK_PACKAGE_10=
PAYMENT_LINK_PACKAGE_50=
PAYMENT_LINK_PACKAGE_100=

# Live English voice preview
DEAPI_API_KEY=

# Live Russian WaveSpeed/MiniMax voice preview
WAVESPEED_API_KEY=
