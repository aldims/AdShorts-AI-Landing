APP_URL=http://127.0.0.1:4174
BETTER_AUTH_URL=http://127.0.0.1:4174
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
AUTH_SERVER_PORT=4175
AUTH_DATABASE_PATH=./data/auth.sqlite

# SMTP for real email delivery. If omitted, local dev falls back to Ethereal preview inbox.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=AdShorts AI <no-reply@adshorts.ai>

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Telegram login is not finalized in production config yet.
# Official Telegram web auth is centered around Login Widget + BotFather /setdomain.
# Keep these empty until Telegram auth is implemented via the official widget flow.
TELEGRAM_CLIENT_ID=
TELEGRAM_CLIENT_SECRET=
