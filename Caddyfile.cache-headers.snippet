# Вставь этот блок ВНУТРИ server { ... } в твоём Caddyfile на сервере.
# Цель: отключить кеширование HTML для Google (бот должен получать 200 с актуальной страницей).
#
# Рекомендуется (все страницы — без кеша):
header {
  Cache-Control "no-store"
}
#
# Либо только no-cache (кеш можно хранить, но перепроверять):
# header {
#   Cache-Control "no-cache"
# }
#
# После правки на сервере: sudo systemctl reload caddy
