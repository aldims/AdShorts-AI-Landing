{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "openrouter": {
      "env": ["OPENROUTER_API_KEY"]
    }
  },
  "tools": {
    "playwright": true
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "enabled": true,
      "command": ["npx", "-y", "@playwright/mcp@latest", "--timeout-action=20000"]
    }
  }
}
